# UberFix.shop environment template
# Frontend-safe variables only belong here.
# Do not place service-role or server-only secrets in any VITE_* variable.

VITE_APP_URL=http://localhost:8080
VITE_PUBLIC_SITE_URL=http://localhost:8080
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_MAPBOX_TOKEN=
VITE_GOOGLE_MAPS_API_KEY=

# Optional local overrides
PORT=8080
CAPACITOR_ENV=false
